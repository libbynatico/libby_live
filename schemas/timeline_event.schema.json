{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TimelineEvent",
  "type": "object",
  "required": ["date", "summary"],
  "properties": {
    "date": { "type": "string", "format": "date" },
    "category": {
      "type": "string",
      "enum": ["medical", "legal", "admin", "system", "personal", "call", "meeting", "deadline"]
    },
    "summary": { "type": "string" },
    "detail": { "type": "string" },
    "outcome": { "type": "string" },
    "documents": {
      "type": "array",
      "items": { "type": "string" },
      "description": "References to evidence_ledger entries"
    },
    "status": {
      "type": "string",
      "enum": ["confirmed", "inferred", "unresolved", "action_required"]
    }
  }
}
